#--------------------------------------------------------------------
# Environment Configuration (Copy ke Railway > Variables)
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://your-app-name.up.railway.app/'
app.rememberSecret = 'GANTI_DENGAN_RANDOM_STRING_YANG_PANJANG'

#--------------------------------------------------------------------
# DATABASE (Railway MySQL - gunakan variable dari Railway)
#--------------------------------------------------------------------

database.default.hostname = ${MYSQLHOST}
database.default.database = ${MYSQLDATABASE}
database.default.username = ${MYSQLUSER}
database.default.password = ${MYSQLPASSWORD}
database.default.DBDriver = MySQLi
database.default.port = ${MYSQLPORT}
